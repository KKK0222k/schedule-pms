<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
       xsi:schemaLocation="http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans-4.0.xsd">

    <bean id="sqlSession" class="org.mybatis.spring.SqlSessionFactoryBean">
        <property name="dataSource" ref="dataSource"/>
        <property name="mapperLocations" value="classpath:/egovframework/sqlmap/example/mappers/*.xml"/>
        <property name="configLocation" value="classpath:/egovframework/sqlmap/example/mybatis-config.xml" />
    </bean>

    <bean class="egovframework.rte.psl.dataaccess.mapper.MapperConfigurer">
        <property name="basePackage" value="com.kkk.schedulepms.schedule.service.impl"/>
    </bean>
    
    <!-- Using mybatis-spring default scanner as fallback -->
    <bean class="org.mybatis.spring.mapper.MapperScannerConfigurer">
        <property name="basePackage" value="com.kkk.schedulepms.schedule.service.impl"/>
        <property name="sqlSessionFactoryBeanName" value="sqlSession"/>
    </bean>

</beans>
